# =============================================================
# kerchi — local environment
# 複製此檔為 .env.local 並填入真實值（請勿把真實金鑰留在此範本檔）。
# =============================================================

# --- Supabase（在 supabase.com 開新專案 → Project Settings → API） ---
# 注意：URL 用「專案根網址」，結尾不要加 /rest/v1/（supabase-js 會自己接路徑）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 本站對外網址（magic link / OG 用）。production 請改成正式網域。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- 考卷解析 provider（後台「拍照建題」用，僅伺服器端讀取） ---
# 有 GOOGLE_API_KEY 就預設用 Gemini；要強制可設 PARSE_PROVIDER=gemini 或 anthropic。
PARSE_PROVIDER=gemini

# Google Gemini（建議；視覺強、有免費額度）— 金鑰從 https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_PARSE_MODEL=gemini-2.5-flash

# Claude（備援，可留空不用）— 從 https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_PARSE_MODEL=claude-sonnet-4-6

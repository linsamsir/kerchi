# =============================================================
# kerchi — local environment
# 複製此檔為 .env.local 並填入真實值（請勿把真實金鑰留在此範本檔）。
# =============================================================

# --- Supabase（在 supabase.com 開新專案 → Project Settings → API） ---
# 注意：URL 用「專案根網址」，結尾不要加 /rest/v1/（supabase-js 會自己接路徑）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 本站對外網址（magic link / OG 用）。production 請改成正式網域。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Claude 視覺 API（後台「拍照建題」用，僅伺服器端讀取） ---
# 從 https://console.anthropic.com/ 取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 解析考卷用的模型（可留空，預設 claude-sonnet-4-6；要最省可用 claude-haiku-4-5）
ANTHROPIC_PARSE_MODEL=claude-sonnet-4-6
